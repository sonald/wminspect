clients: filter;
attrs.map_state=Viewable: filter;
geom.width>=160: filter;
geom.height>=120: filter;
not(any(
    name=*dock*,
    name=*panel*,
    name=*toolbar*,
    name=*desktop*,
    name=*notification*,
    name=*launchpad*,
    name=*clipboard*,
    name=*dde-shell*,
    name=xfce4-*,
    name=gnome-*
)): filter
